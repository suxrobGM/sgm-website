# Real secrets only — non-secret config stays in appsettings.json.
# Copy to .env for local docker compose runs. In CI, the contents of the
# ENV_DOCKER GitHub secret are written here by the deploy workflow.

# ASP.NET Core maps `Section__Key` to Section:Key in IConfiguration.

EmailConfig__ApiKey=re_your_resend_api_key

# FreeKassa — suxrobgm.net is the registered merchant (proxies payments for meat.gg).
# MeatggCallbackUrl/PayUrl are non-secret and live in appsettings.json.
FreeKassa__MerchantId=your_freekassa_merchant_id
FreeKassa__Secret1=your_freekassa_secret_word_1
FreeKassa__Secret2=your_freekassa_secret_word_2
# Shared HMAC for the meat.gg <-> suxrobgm.net hop; MUST match meat.gg FREEKASSA_PROXY_SECRET.
FreeKassa__ProxySecret=shared_hmac_secret
