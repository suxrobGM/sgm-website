@* Shared chrome for the payment pages: full-bleed background, centered card, optional FreeKassa brand. *@

<div class="pay-wrap">
  <div class="pay-card@(Centered ? " pay-center" : null)">
    @if (!string.IsNullOrEmpty(BrandName))
    {
      <div class="pay-brand">
        <div class="logo">FK</div>
        <div class="name">
          @BrandName
          <small>@BrandTagline</small>
        </div>
      </div>
    }

    @ChildContent
  </div>
</div>

@code {
    [Parameter] public string? BrandName { get; set; }
    [Parameter] public string? BrandTagline { get; set; }
    [Parameter] public bool Centered { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
}
